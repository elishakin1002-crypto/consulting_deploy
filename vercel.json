{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "functions": {
        "api/*.py": {
            "maxDuration": 60
        }
    },
    "rewrites": [
        {
            "source": "/api/chat",
            "destination": "/api/index.py"
        },
        {
            "source": "/",
            "destination": "/public/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/public/$1"
        }
    ]
}
